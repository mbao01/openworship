<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Hardened Runtime: required for notarization -->

    <!-- Allow JIT compilation (WKWebView / Tauri's renderer) -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>

    <!-- Allow unsigned memory (required by some Tauri internals) -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>

    <!-- Disable library validation so bundled dylibs can be loaded -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>

    <!-- Microphone: used for speech-to-text (Whisper / Deepgram) -->
    <key>com.apple.security.device.audio-input</key>
    <true/>

    <!-- Outbound network: used for Deepgram online STT -->
    <key>com.apple.security.network.client</key>
    <true/>
</dict>
</plist>
