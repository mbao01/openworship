{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenWorship",
  "version": "0.4.0",
  "identifier": "com.openworship.app",
  "build": {
    "beforeDevCommand": "pnpm --filter @openworship/web dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm --filter @openworship/web build",
    "frontendDist": "../../apps/web/dist"
  },
  "app": {
    "windows": [
      {
        "title": "OpenWorship",
        "width": 1200,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: asset: https://asset.localhost owmedia:; media-src 'self' blob: asset: https://asset.localhost owmedia:; font-src 'self' https://fonts.gstatic.com; connect-src 'self' ws://127.0.0.1:9000 https://fonts.googleapis.com; object-src 'none'",
      "assetProtocol": {
        "scope": [
          "$HOME/.openworship/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "resources/*"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "infoPlist": "Info.plist",
      "entitlements": "entitlements.plist"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDMyMTAyQTVGQTVCOTYxODMKUldTRFlibWxYeW9RTWx6cjZqSDVCODNnUjdIQlQ3eDdMcERwUUZPTWp4b3E0TCtTcndjUkl6MHIK",
      "endpoints": [
        "https://github.com/mbao01/openworship/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
